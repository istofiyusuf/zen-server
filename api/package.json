{
  "name": "zen-server",
  "version": "1.0.0",
  "description": "Android Web Server Dashboard for Termux",
  "main": "server.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "format": "prettier --write .",
    "server": "node api/server.js",
    "server:termux": "node api/server-termux.js",
    "dev:server": "nodemon api/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "postinstall": "node -e \"try{require('prisma')}catch(e){console.log('Prisma not available')}\"",
    "setup": "npm install --legacy-peer-deps && npm run build",
    "setup:termux": "npm install --legacy-peer-deps --no-optional && npm install bcryptjs --legacy-peer-deps && npm run build",
    "clean": "rm -rf .next node_modules package-lock.json",
    "check": "bash scripts/check.sh",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "start:all": "concurrently \"npm run server\" \"npm run dev\"",
    "start:termux": "concurrently \"npm run server:termux\" \"npm start\""
  },
  "keywords": [
    "android",
    "termux",
    "web-server",
    "dashboard",
    "server-management"
  ],
  "author": "Istofi Yusuf",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-accordion": "1.1.2",
    "@radix-ui/react-avatar": "1.0.4",
    "@radix-ui/react-dialog": "1.0.5",
    "@radix-ui/react-dropdown-menu": "2.0.6",
    "@radix-ui/react-label": "2.0.2",
    "@radix-ui/react-popover": "1.0.7",
    "@radix-ui/react-progress": "1.0.3",
    "@radix-ui/react-scroll-area": "1.0.5",
    "@radix-ui/react-select": "2.0.0",
    "@radix-ui/react-separator": "1.0.3",
    "@radix-ui/react-slider": "1.1.2",
    "@radix-ui/react-slot": "1.0.2",
    "@radix-ui/react-switch": "1.0.3",
    "@radix-ui/react-tabs": "1.0.4",
    "@radix-ui/react-toast": "1.1.5",
    "@radix-ui/react-tooltip": "1.0.7",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.0",
    "cors": "2.8.5",
    "express": "4.21.0",
    "express-rate-limit": "7.4.0",
    "framer-motion": "10.18.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "0.312.0",
    "next": "14.2.0",
    "next-themes": "0.3.0",
    "react": "18.3.0",
    "react-dom": "18.3.0",
    "react-icons": "5.0.0",
    "socket.io": "4.7.0",
    "socket.io-client": "4.7.0",
    "tailwind-merge": "2.2.0",
    "zod": "3.23.0",
    "zustand": "4.5.0"
  },
  "optionalDependencies": {
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0",
    "bcrypt": "5.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.17.0",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.17",
    "concurrently": "8.2.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.0",
    "nodemon": "3.1.0",
    "postcss": "8.4.35",
    "prettier": "3.2.0",
    "prettier-plugin-tailwindcss": "0.5.0",
    "tailwindcss": "3.4.0",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  }
}
